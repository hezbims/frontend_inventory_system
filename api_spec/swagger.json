          },
          "current_page": {
            "type": "integer",
            "format": "int32"
          },
          "next_page": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "prev_page": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "total_page": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
