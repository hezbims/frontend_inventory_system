              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login Sukses",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/LoginSucceedResponse"
                },
                "example": {"token":"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..H46pIQejekT9s-GuXsEauIqGjK2zu2vitYyWAhLRu8Y","user":{"id":1,"username":"admin","is_admin":true},"message":"Sukses"}
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginSucceedResponse"
                },
                "example": {"token":"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..H46pIQejekT9s-GuXsEauIqGjK2zu2vitYyWAhLRu8Y","user":{"id":1,"username":"admin","is_admin":true},"message":"Sukses"}
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginSucceedResponse"
                },
                "example": {"token":"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..H46pIQejekT9s-GuXsEauIqGjK2zu2vitYyWAhLRu8Y","user":{"id":1,"username":"admin","is_admin":true},"message":"Sukses"}
              }
            }
          },
          "400": {
            "description": "Login gagal",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/LoginFailedResponse"
                },
                "example": {"message":"Username atau password salah"}
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginFailedResponse"
                },
                "example": {"message":"Username atau password salah"}
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginFailedResponse"
                },
                "example": {"message":"Username atau password salah"}
              }
            }
          }
        }
      }
    },
