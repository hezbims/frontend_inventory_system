          "data": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/BarangDto"
            }
          },
          "links": {
            "$ref": "#/components/schemas/BarangDtoLinkInfo"
          }
        },
        "additionalProperties": false
      },
      "GetCurrentUserSucceedResponse": {
        "type": "object",
        "properties": {
