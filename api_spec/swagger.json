          },
          "min_stock": {
            "type": "integer",
            "format": "int32"
          },
          "nomor_rak": {
            "type": "integer",
            "format": "int32"
          },
          "nomor_laci": {
            "type": "integer",
            "format": "int32"
          },
          "nomor_kolom": {
            "type": "integer",
            "format": "int32"
          },
          "stock_sekarang": {
            "type": "integer",
            "format": "int32"
          },
          "last_month_stock": {
            "type": "integer",
            "format": "int32"
          },
          "unit_price": {
            "type": "integer",
            "format": "int32"
          },
          "uom": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "BarangDtoLinkInfo": {
        "type": "object",
        "properties": {
          "next": {
            "type": "boolean",
