            "type": "integer",
            "format": "int32"
          },
          "username": {
            "type": "string"
          },
          "is_admin": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "KategoriDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "nama": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "LoginFailedResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "username": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "LoginSucceedResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          },
          "user": {
            "$ref": "#/components/schemas/GetUserDto"
          },
          "message": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "PostBarangDto": {
        "required": [
          "kategori_id",
          "kode_barang",
          "last_month_stock",
          "min_stock",
          "nama",
          "nomor_kolom",
          "nomor_laci",
          "nomor_rak",
          "stock_sekarang",
          "unit_price",
          "uom"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "nama": {
            "minLength": 1,
            "type": "string"
          },
          "kode_barang": {
            "minLength": 1,
            "type": "string"
          },
          "nomor_rak": {
            "maximum": 6,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "nomor_laci": {
            "maximum": 30,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "nomor_kolom": {
            "maximum": 9,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "stock_sekarang": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "last_month_stock": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "min_stock": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "unit_price": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          },
          "uom": {
            "minLength": 1,
            "type": "string"
          },
          "kategori_id": {
            "maximum": 2147483647,
            "minimum": 1,
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "PostKategoriDto": {
        "required": [
          "nama"
        ],
        "type": "object",
        "properties": {
          "nama": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "PostNewPengajuDto": {
        "required": [
          "is_pemasok",
          "nama"
        ],
        "type": "object",
        "properties": {
          "is_pemasok": {
            "type": "boolean"
          },
          "nama": {
            "minLength": 1,
            "type": "string"
          }
        },
